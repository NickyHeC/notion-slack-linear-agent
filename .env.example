# Dedalus API Key
DEDALUS_API_KEY=

# Notion Internal Integration Token
NOTION_API_KEY=

# Slack User/Bot Token
SLACK_ACCESS_TOKEN=

# Linear API Key (optional — leave empty if using OAuth)
LINEAR_API_KEY=

# MCP server slugs on Dedalus marketplace
NOTION_MCP_SERVER=nickyhec/notion-mcp
SLACK_MCP_SERVER=nickyhec/slack-mcp
LINEAR_MCP_SERVER=nickyhec/linear-mcp

# Slack workspace slug (for generating thread links)
SLACK_WORKSPACE=

# --- platforms_sync_report.py ---
SPRINT_PAGE=                # Notion sprint page title
SLACK_CHANNEL=general       # Slack channel to read (without #)
LINEAR_TEAM=                # Linear team name (empty = all teams)

# --- slack_tasks_compilation.py ---
SLACK_TASKS_PERSON=         # Person whose tasks to compile
SLACK_TASKS_DAYS=7          # Lookback window in days

# --- sync_to_linear.py ---
LINEAR_PROJECT=             # Linear project for synced issues
LINEAR_TEAM_SYNC=           # Linear team for synced issues
GAP_ANALYSIS_PATH=          # Path to Gap Analysis xlsx
GAP_ANALYSIS_URL=           # Google Sheets URL for Gap Analysis

# LLM model
MODEL=anthropic/claude-sonnet-4-20250514

# Agent timeout in seconds
AGENT_TIMEOUT=900
